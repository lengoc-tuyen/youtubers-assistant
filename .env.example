# Literal drafts use the local Python package: `translate` (English → Vietnamese).

# Groq: https://api.groq.com/openai/v1/chat/completions is used when omitted.
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Bounded HTTP behavior. API keys are never written to cache or artifacts.
PROVIDER_TIMEOUT_SECONDS=30
PROVIDER_MAX_RETRIES=3
